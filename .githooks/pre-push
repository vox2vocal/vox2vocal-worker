#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
validator="$repo_root/scripts/validate-git-policy.sh"
remote_name="${1:-origin}"

"$validator" --check-config

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "${local_ref:-}" ] || continue

  case "$local_sha" in
    0000000000000000000000000000000000000000)
      continue
      ;;
  esac

  "$validator" --push-ref "$local_ref" "$remote_ref"

  case "$remote_sha" in
    0000000000000000000000000000000000000000)
      commits="$(git rev-list --reverse "$local_sha" --not --remotes="$remote_name" || true)"
      if [ -z "$commits" ]; then
        "$validator" --commit "$local_sha"
      else
        while IFS= read -r sha; do
          [ -n "$sha" ] || continue
          "$validator" --commit "$sha"
        done <<EOF
$commits
EOF
      fi
      ;;
    *)
      "$validator" --range "$remote_sha" "$local_sha"
      ;;
  esac
done
